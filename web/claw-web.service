[Unit]
Description=claw-monitor web dashboard (Next.js on port 7432)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/work/claw-monitor/web
ExecStart=/usr/bin/node %h/work/claw-monitor/web/node_modules/.bin/next start -p 7432 -H 0.0.0.0
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=7432

[Install]
WantedBy=default.target
